# Firebase Web Configuration (from Firebase Console → Project Settings → Web App)
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
FIREBASE_WEB_APP_ID=1:000000000000:web:0000000000000000000000
FIREBASE_WEB_MESSAGING_SENDER_ID=000000000000
FIREBASE_WEB_PROJECT_ID=dhamma-65bde
FIREBASE_WEB_STORAGE_BUCKET=dhamma-65bde.appspot.com
FIREBASE_WEB_AUTH_DOMAIN=dhamma-65bde.firebaseapp.com

# AI Service (self-hosted Node.js backend or Cloud Function URL)
AI_SERVICE_BASE_URL=https://api.dhamma-plus.app/api/ai
